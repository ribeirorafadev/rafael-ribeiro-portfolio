---
// Importação dos componentes modulares que compõem a barra lateral
import SideBarFooter from "./SideBarFooter.astro";
import { Image } from "astro:assets";
import SideBarMenu from "./SideBarMenu.astro";
const { sideBarActiveItemID } = Astro.props;
---

<!-- Container lateral fixo e sobreposição para versão mobile -->
<div class="drawer-side z-40">
  <label for="my-drawer" class="drawer-overlay"></label>
  <aside
    class="relative px-2 pt-2 h-auto min-h-full w-[19rem] bg-base-200 text-base-content flex flex-col overflow-hidden"
  >
    <!-- Fundo Animado da Barra Lateral -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-30">
      <div
        class="absolute -top-10 -left-10 w-48 h-48 bg-primary rounded-full mix-blend-screen filter blur-[60px] animate-blob"
      >
      </div>
      <div
        class="absolute top-1/2 -right-10 w-48 h-48 bg-secondary rounded-full mix-blend-screen filter blur-[60px] animate-blob"
        style="animation-delay: 2s;"
      >
      </div>
      <div
        class="absolute -bottom-10 left-10 w-48 h-48 bg-accent rounded-full mix-blend-screen filter blur-[60px] animate-blob"
        style="animation-delay: 4s;"
      >
      </div>
    </div>

    <!-- Ícone de fechar o menu (Exclusivo para Mobile) -->
    <div class="absolute top-4 left-3 lg:hidden z-50">
      <label
        for="my-drawer"
        class="btn btn-ghost btn-square btn-sm"
        aria-label="Fechar menu"
      >
        <i class="fa-solid fa-xmark text-xl"></i>
      </label>
    </div>

    <div class="relative z-10 w-fit mx-auto mt-5 mb-2">
      <a href="/">
        <!-- Avatar e imagem de perfil estendida e animada ao passar o mouse -->
        <div
          class="avatar transition-all duration-300 ease-in-out hover:scale-[105%] active:scale-95 block m-auto"
        >
          <div class="w-[8.5rem]">
            <Image
              class="mask mask-circle"
              format="webp"
              width={300}
              height={300}
              src="/profile.webp"
              alt="Profile image"
            />
          </div>
        </div>
      </a>
    </div>

    <!-- Nome em destaque com efeito de texto em gradiente -->
    <div
      class="hidden lg:block relative z-10 text-2xl font-extrabold tracking-tight text-center bg-gradient-to-r from-gray-200 via-gray-400 to-gray-500 bg-clip-text text-transparent mb-2"
    >
      Rafael Ribeiro
    </div>

    <!-- Menu dinâmico de navegação entre as seções -->
    <SideBarMenu sideBarActiveItemID={sideBarActiveItemID} />
    <!-- Rodapé da barra com redes sociais e direitos autorais -->
    <SideBarFooter />
  </aside>
</div>
