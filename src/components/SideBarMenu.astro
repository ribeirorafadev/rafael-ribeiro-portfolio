---
// Recebe as propriedades passadas para o componente, se houver
const { sideBarActiveItemID } = Astro.props;
---

<!-- Navegação âncora da SPA (Single Page Application) -->
<ul
  class="relative z-10 menu grow shrink overflow-y-auto flex flex-col items-center lg:items-stretch w-full gap-2 lg:gap-0 mt-8 lg:mt-0"
>
  <li class="w-full max-w-[250px] lg:max-w-full">
    <a
      class="justify-center lg:justify-start py-4 lg:py-3 text-xl lg:text-base w-full"
      id="home"
      href="/#home">Início</a
    >
  </li>
  <li class="w-full max-w-[250px] lg:max-w-full">
    <a
      class="justify-center lg:justify-start py-4 lg:py-3 text-xl lg:text-base w-full"
      id="projects"
      href="/#projects">Projetos</a
    >
  </li>
  <li class="w-full max-w-[250px] lg:max-w-full">
    <a
      class="justify-center lg:justify-start py-4 lg:py-3 text-xl lg:text-base w-full"
      id="works"
      href="/#works">Experiência</a
    >
    <li class="w-full max-w-[250px] lg:max-w-full">
      <a
        class="justify-center lg:justify-start py-4 lg:py-3 text-xl lg:text-base w-full"
        id="skills"
        href="/#skills">Habilidades</a
      >
    </li>
    <li class="w-full max-w-[250px] lg:max-w-full">
      <a
        class="justify-center lg:justify-start py-4 lg:py-3 text-xl lg:text-base w-full"
        id="education"
        href="/#education">Formação</a
      >
    </li>
  </li>
  <li class="w-full max-w-[250px] lg:max-w-full">
    <a
      class="justify-center lg:justify-start py-4 lg:py-3 text-xl lg:text-base w-full"
      id="contact"
      href="/#contact">Contato</a
    >
  </li>
</ul>

<script>
  // Função nativa JavaScript que identifica automaticamente qual seção está visível na tela e acende o menu correspondente
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            // Itera os links e altera as propriedades de cor/fundo de acordo com a visão do usuário
            document.querySelectorAll(".menu a").forEach((link) => {
              // Remove o destaque de todos os links
              link.classList.remove(
                "bg-base-content/10",
                "text-primary",
                "font-bold",
              );
              // Adiciona o destaque ao link correspondente à seção visível na tela
              if (link.getAttribute("href") === `/#${id}`) {
                link.classList.add(
                  "bg-base-content/10",
                  "text-primary",
                  "font-bold",
                );
              }
            });
          }
        });
      },
      { threshold: 0.3, rootMargin: "0px 0px -40% 0px" },
    );

    // Pede ao observador para ficar de olho em todas as tags <section> que possuam um ID
    document.querySelectorAll("section[id]").forEach((section) => {
      observer.observe(section);
    });

    // Fecha o menu mobile automaticamente ao clicar em um link
    document.querySelectorAll(".menu a").forEach((link) => {
      link.addEventListener("click", () => {
        const drawer = document.getElementById(
          "my-drawer",
        ) as HTMLInputElement | null;
        if (drawer && window.innerWidth < 1024) {
          drawer.checked = false;
        }
      });
    });
  });
</script>
