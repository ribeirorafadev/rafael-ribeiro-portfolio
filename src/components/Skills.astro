---
type SkillItem =
  | {
      name: string;
      icon: string;
      isFontAwesome?: false;
    }
  | {
      name: string;
      icon: string;
      isFontAwesome: true;
      iconColor?: string;
    };

type SkillGroup = {
  label: string;
  items: SkillItem[];
};

const skillGroups: SkillGroup[] = [
  {
    label: "Backend",
    items: [
      {
        name: "Java",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg",
      },
      {
        name: "Python",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg",
      },
      {
        name: "Spring Boot",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/spring/spring-original.svg",
      },
      {
        name: "Node.js",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg",
      },
      {
        name: "MySQL",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg",
      },
      {
        name: "SQLite",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/sqlite/sqlite-original.svg",
      },
    ],
  },
  {
    label: "Frontend",
    items: [
      {
        name: "JavaScript",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg",
      },
      {
        name: "HTML5",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg",
      },
      {
        name: "CSS3",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/css3/css3-original.svg",
      },
    ],
  },
  {
    label: "Ferramentas",
    items: [
      {
        name: "Git",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg",
      },
      {
        name: "GitHub",
        icon: "https://cdn.simpleicons.org/github/E6EDF3",
      },
      {
        name: "Vercel",
        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vercel/vercel-original.svg",
      },
    ],
  },
  {
    label: "Metodologias",
    items: [
      {
        name: "Scrum",
        icon: "fa-solid fa-rotate",
        isFontAwesome: true,
        iconColor: "text-green-400",
      },
      {
        name: "Kanban",
        icon: "fa-solid fa-table-columns",
        isFontAwesome: true,
        iconColor: "text-purple-400",
      },
    ],
  },
];
---

<section
  id="skills"
  class="pb-12 flex flex-col items-center md:items-start text-center md:text-left gap-6 mt-4"
>
  <div
    class="inline-block w-fit px-3 py-1 text-xs font-semibold tracking-widest text-base-content/70 uppercase border border-base-content/20 rounded-full"
  >
    Habilidades
  </div>

  <div class="flex flex-col gap-6 w-full">
    <div
      class="mx-auto flex w-fit max-w-full flex-wrap items-center justify-center gap-x-3 gap-y-2 md:mx-0 md:justify-start"
    >
      {
        skillGroups.map((group, index) => (
          <>
            {index > 0 && (
              <span class="inline text-base-content/30 font-light">/</span>
            )}
            <span class="text-sm md:text-base font-extrabold uppercase tracking-widest bg-gradient-to-r from-gray-200 via-gray-400 to-gray-500 bg-clip-text text-transparent drop-shadow-[0_0_12px_rgba(255,255,255,0.15)] transition-all duration-300">
              {group.label}
            </span>
          </>
        ))
      }
    </div>

    <div
      class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6"
    >
      {
        skillGroups
          .flatMap((group) => group.items)
          .map((skill) => (
            <div class="flex min-h-[56px] items-center justify-center gap-2.5 rounded-2xl border border-base-content/20 bg-base-200/80 px-3 py-2.5 shadow-md shadow-black/30 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:border-sky-400/40 hover:bg-base-200">
              {skill.isFontAwesome ? (
                <i
                  class={`${skill.icon} ${skill.iconColor ?? "text-base-content"} text-lg drop-shadow-md`}
                />
              ) : (
                <img
                  src={skill.icon}
                  alt={skill.name}
                  class={`h-5 w-5 drop-shadow-md ${skill.name === "Vercel" ? "invert" : ""}`}
                />
              )}
              <span class="truncate text-sm font-bold text-base-content drop-shadow-sm">
                {skill.name}
              </span>
            </div>
          ))
      }
    </div>
  </div>
</section>
