---
// Componente da Seção de Habilidades
---

<!-- Container modular responsivo pelas listagens das tecnologias e proficiências -->
<section
  id="skills"
  class="pb-12 flex flex-col items-center md:items-start text-center md:text-left gap-8 mt-4"
>
  <div
    class="inline-block w-fit px-3 py-1 text-xs font-semibold tracking-widest text-base-content/70 uppercase border border-base-content/20 rounded-full"
  >
    Habilidades
  </div>

  <!-- Categoria: Backend -->
  <div class="w-full flex flex-col items-center md:items-start gap-4">
    <h3
      class="text-sm font-bold tracking-widest bg-gradient-to-r from-gray-200 via-gray-400 to-gray-500 bg-clip-text text-transparent uppercase"
    >
      Backend
    </h3>
    <div class="flex flex-wrap justify-center md:justify-start gap-3">
      <!-- Cards de Tecnologia -->
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg"
          alt="Java"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">Java</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"
          alt="Python"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">Python</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/spring/spring-original.svg"
          alt="Spring Boot"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">Spring Boot</span
        >
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg"
          alt="Node.js"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">Node.js</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg"
          alt="MySQL"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">MySQL</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/sqlite/sqlite-original.svg"
          alt="SQLite"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">SQLite</span>
      </div>
    </div>
  </div>

  <!-- Categoria: Frontend -->
  <div class="w-full flex flex-col items-center md:items-start gap-4">
    <h3
      class="text-sm font-bold tracking-widest bg-gradient-to-r from-gray-200 via-gray-400 to-gray-500 bg-clip-text text-transparent uppercase"
    >
      Frontend
    </h3>
    <div class="flex flex-wrap justify-center md:justify-start gap-3">
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg"
          alt="JavaScript"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">JavaScript</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg"
          alt="HTML5"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">HTML5</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/css3/css3-original.svg"
          alt="CSS3"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">CSS3</span>
      </div>
    </div>
  </div>

  <!-- Categoria: Ferramentas -->
  <div class="w-full flex flex-col items-center md:items-start gap-4">
    <h3
      class="text-sm font-bold tracking-widest bg-gradient-to-r from-gray-200 via-gray-400 to-gray-500 bg-clip-text text-transparent uppercase"
    >
      Ferramentas
    </h3>
    <div class="flex flex-wrap justify-center md:justify-start gap-3">
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg"
          alt="Git"
          class="w-5 h-5"
        />
        <span class="text-sm font-medium text-base-content/80">Git</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <i class="fa-brands fa-github text-[#E6EDF3] text-xl"></i>
        <span class="text-sm font-medium text-base-content/80">GitHub</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <img
          src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vercel/vercel-original.svg"
          alt="Vercel"
          class="w-5 h-5 invert opacity-90"
        />
        <span class="text-sm font-medium text-base-content/80">Vercel</span>
      </div>
    </div>
  </div>

  <!-- Categoria: Metodologias -->
  <div class="w-full flex flex-col items-center md:items-start gap-4">
    <h3
      class="text-sm font-bold tracking-widest bg-gradient-to-r from-gray-200 via-gray-400 to-gray-500 bg-clip-text text-transparent uppercase"
    >
      Metodologias
    </h3>
    <div class="flex flex-wrap justify-center md:justify-start gap-3">
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <i class="fa-solid fa-users-gear text-blue-400 text-lg"></i>
        <span class="text-sm font-medium text-base-content/80"
          >Metodologias Ágeis</span
        >
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <i class="fa-solid fa-rotate text-green-400 text-lg"></i>
        <span class="text-sm font-medium text-base-content/80">Scrum</span>
      </div>
      <div
        class="flex items-center gap-2 px-4 py-2 rounded-xl bg-base-200/50 border border-base-content/10 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-base-content/20"
      >
        <i class="fa-solid fa-table-columns text-purple-400 text-lg"></i>
        <span class="text-sm font-medium text-base-content/80">Kanban</span>
      </div>
    </div>
  </div>
</section>
